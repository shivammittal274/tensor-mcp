{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@activepieces/pieces-framework": [
        "./packages/core/src/services/adapt/activepieces/framework"
      ],
      "@activepieces/pieces-common": [
        "./packages/core/src/services/adapt/activepieces/common"
      ],
      "@activepieces/shared": [
        "./packages/core/src/services/adapt/activepieces/shared"
      ]
    }
  }
}
