{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["bun"],
    // The lifted Activepieces source (`src/services/local/**`) was authored
    // against a non-strict tsconfig upstream (their `tsconfig.base.json`
    // does not enable `strict`). To ship those files unedited, we relax
    // strictness package-wide. Our own code still gets `noImplicitOverride`,
    // `noFallthroughCasesInSwitch`, and `noImplicitReturns` via explicit
    // re-enables below.
    "strict": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
